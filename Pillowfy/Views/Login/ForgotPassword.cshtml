@{
    ViewData["Title"] = "Mot de passe oublié";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pillowfy — Mot de passe oublié</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --gold: #C9A96E;
            --ink: #0F1621;
            --ink-60: rgba(15,22,33,0.60);
            --ink-30: rgba(15,22,33,0.30);
            --cream: #FAF7F2;
            --white: #FFFFFF;
            --teal: #1A6B6B;
            --radius-xl: 32px;
            --shadow-lg: 0 20px 60px rgba(15,22,33,0.16);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--ink);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background: radial-gradient(ellipse 70% 60% at 80% 20%, rgba(201,169,110,0.12) 0%, transparent 65%), radial-gradient(ellipse 50% 50% at 10% 80%, rgba(26,107,107,0.07) 0%, transparent 60%);
                pointer-events: none;
                z-index: 0;
            }

        .card {
            position: relative;
            z-index: 1;
            background: var(--white);
            border-radius: var(--radius-xl);
            padding: 3rem 2.8rem;
            width: 100%;
            max-width: 440px;
            box-shadow: var(--shadow-lg);
            border: 1px solid rgba(201,169,110,0.15);
            animation: fadeUp 0.5s ease both;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 2.2rem;
            text-decoration: none;
        }

        .brand-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            overflow: hidden;
        }

        .brand-name {
            font-family: 'DM Serif Display', serif;
            font-size: 1.4rem;
            color: var(--ink);
        }

        .card-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 1.4px;
            text-transform: uppercase;
            color: var(--teal);
            margin-bottom: 0.6rem;
        }

            .card-eyebrow::before {
                content: '';
                display: block;
                width: 20px;
                height: 1.5px;
                background: var(--teal);
            }

        h1 {
            font-family: 'DM Serif Display', serif;
            font-size: 1.9rem;
            line-height: 1.2;
            color: var(--ink);
            margin-bottom: 0.5rem;
        }

            h1 em {
                font-style: italic;
                color: var(--gold);
            }

        .subtitle {
            font-size: 0.92rem;
            font-weight: 300;
            color: var(--ink-60);
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

        label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 0.4rem;
        }

        input {
            width: 100%;
            padding: 0.78rem 1rem;
            border: 1.5px solid var(--ink-30);
            border-radius: 12px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.92rem;
            color: var(--ink);
            background: var(--cream);
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }

            input:focus {
                border-color: var(--gold);
                box-shadow: 0 0 0 3px rgba(201,169,110,0.12);
                background: var(--white);
            }

            input::placeholder {
                color: var(--ink-30);
            }

        .btn {
            width: 100%;
            padding: 0.88rem;
            border-radius: 100px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.96rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all .22s cubic-bezier(.4,0,.2,1);
            margin-top: 0.5rem;
        }

        .btn-gold {
            background: var(--gold);
            color: var(--ink);
        }

            .btn-gold:hover {
                background: #b8924f;
                box-shadow: 0 6px 28px rgba(201,169,110,0.40);
                transform: translateY(-2px);
            }

        .back-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            margin-top: 1.5rem;
            font-size: 0.88rem;
            color: var(--ink-60);
            text-decoration: none;
            transition: color .2s;
        }

            .back-link:hover {
                color: var(--ink);
            }

        .alert {
            padding: 0.8rem 1rem;
            border-radius: 12px;
            font-size: 0.88rem;
            margin-bottom: 1.2rem;
            display: none;
        }

        .alert-success {
            background: rgba(26,107,107,0.1);
            color: var(--teal);
            border: 1px solid rgba(26,107,107,0.2);
        }

        .alert-error {
            background: rgba(220,38,38,0.08);
            color: #dc2626;
            border: 1px solid rgba(220,38,38,0.2);
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(22px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <div class="card">
        <a href="/" class="brand">
            <img src="/Images/logo.png" alt="Pillowfy" class="brand-icon">
            <span class="brand-name">Pillowfy</span>
        </a>
        <span class="card-eyebrow">Securite</span>
        <h1>Mot de passe<br><em>oublie ?</em></h1>
        <p class="subtitle">Entrez votre adresse e-mail et nous vous enverrons un lien pour reinitialiser votre mot de passe.</p>
        <div class="alert alert-success" id="alertSuccess">E-mail envoye ! Verifiez votre boite de reception.</div>
        <div class="alert alert-error" id="alertError">Une erreur est survenue. Veuillez reessayer.</div>
        <div class="form-group">
            <label for="email">Adresse e-mail</label>
            <input type="email" id="email" placeholder="vous@@exemple.com" />
        </div>
        <button class="btn btn-gold" onclick="sendReset()">Envoyer le lien</button>
        <a href="/Login/Index" class="back-link">Retour a la connexion</a>
    </div>
    <script>
        async function sendReset() {
            const email = document.getElementById('email').value.trim();
            const successEl = document.getElementById('alertSuccess');
            const errorEl = document.getElementById('alertError');
            successEl.style.display = 'none';
            errorEl.style.display = 'none';
            if (!email) {
                errorEl.textContent = 'Veuillez entrer votre adresse e-mail.';
                errorEl.style.display = 'block';
                return;
            }
            try {
                const res = await fetch('/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                if (res.ok) {
                    successEl.style.display = 'block';
                } else {
                    errorEl.textContent = 'E-mail introuvable dans notre systeme.';
                    errorEl.style.display = 'block';
                }
            } catch {
                errorEl.textContent = 'Erreur de connexion. Reessayez.';
                errorEl.style.display = 'block';
            }
        }
    </script>
</body>
</html>